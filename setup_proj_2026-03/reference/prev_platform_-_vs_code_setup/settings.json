{
    // General & VS Code Settings

    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.confirmPasteNative": false,

    "workbench.startupEditor": "none",
    "workbench.preferredHighContrastColorTheme": "Default Light Modern",
    "workbench.colorTheme": "Night Owl Black (No Italics)",
    
    "terminal.integrated.shellIntegration.enabled": false,
    "terminal.integrated.enablePersistentSessions": false,
    "python.terminal.activateEnvironment": false,

    "editor.minimap.enabled": false,
    "editor.parameterHints.enabled": false,

    /// Suggestion & tab completion behavior

    "editor.acceptSuggestionOnEnter": "off",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.tabCompletion": "on",
    "editor.quickSuggestions": {
		"other": "on",
		"comments": "off",
		"strings": "off"
	},
    
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "editor.suggest.filterGraceful": false,

    "cSpell.useGitignore": false,
    
    /// Auto completion (turned off)

    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "css.completion.completePropertyWithSemicolon": false,
      
    /// Jupyter

    "notebook.lineNumbers": "on",
    "workbench.panel.defaultLocation": "right",
    "workbench.panel.opensMaximized": "always",
    "jupyter.interactiveWindow.codeLens.enable": false,
    "jupyter.askForKernelRestart": false,
    "jupyter.interactiveWindow.textEditor.executeSelection": true,
    "notebook.output.wordWrap": true,

    /// Git

    "git.scanRepositories": [
        "C:\\Users\\mtbv\\mtb\\docs\\work\\1_repos",
    ],
    "git.autofetch": true,
    "git.countBadge": "off",
    "git.rebaseWhenSync": true,
    "git.showPushSuccessNotification": true,
    "git.showActionButton": {
        "commit": false,
        "publish": false,
        "sync": false
    },
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "never",

    /// Markdown & Markdown Related

    "markdown.validate.enabled": true,
    "markdown.validate.referenceLinks.enabled": "ignore"
    // "markdown.extension.print.onFileSave": true,
    "markdown.extension.print.absoluteImgPath": false,
    "markdownlint.config": {
        "default": true,
        "MD033": false,
        "MD045": false,
        "MD036": false,
        "MD024": false,
    "markdown.lint.enabled": false
    },
    // "markdown-preview-github-styles.colorTheme": "light",
    "editor.rulers": [
        80
    ],

    "inlineFold.regex": "\\[([^\\]]*)\\]\\(([^\\s]+)\\)[^\\)\\s]*\\s",
    "inlineFold.regexFlags": "g",
    "inlineFold.regexGroup": 2,
    "inlineFold.supportedLanguages": [
        "markdown"
    ],

    "pasteImage.path": "${projectRoot}/pages/images",
    "pasteImage.basePath": "${projectRoot}/pages",
    "pasteImage.prefix": "/",
    "pasteImage.namePrefix": "blog-",
    "pasteImage.nameSuffix": "-${currentFileNameWithoutExt}",
    "pasteImage.insertPattern": "![${imageFileName}](${imageFilePath})",

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "heading.1.markdown",
                "settings": {
                    "foreground": "#B0B0B0",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "heading.2.markdown",
                "settings": {
                    "foreground": "#00D4AA"
                }
            },
            {
                "scope": "heading.3.markdown",
                "settings": {
                    "foreground": "#FFB347"
                }
            },
            {
                "scope": "heading.4.markdown",
                "settings": {
                    "foreground": "#A0A0A0"
                }
            },
            {
                "scope": "heading.5.markdown",
                "settings": {
                    "foreground": "#A0A0A0"
                }
            }
        ]
    },

    "projectManager.git.baseFolders": [        
        "/mnt/ssd2_data/documents"
    ],
    "projectManager.git.maxDepthRecursion": 0,
    
    // Random

    "vscode-edge-devtools.webhintInstallNotification": true,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "claudeCode.preferredLocation": "sidebar",

}